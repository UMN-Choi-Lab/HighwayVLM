OPENAI_API_KEY=replace-me
VLM_MODEL=gpt-4o-mini
SYSTEM_INTERVAL_SECONDS=30

# VESSL data2 volume root.
# Common value for your setup: /data2/data-storage
DATA2_VOLUME_PATH=/data2/data-storage

# Host path mounted into the container for long-term raw video archives.
VIDEO_ARCHIVE_HOST_PATH=/data2/HighwayVLM

# Persist HLS video segments for manual cross-referencing with incident history.
VIDEO_ARCHIVE_ENABLED=true
VIDEO_ARCHIVE_ALIGN_TO_HOUR=true
VIDEO_ARCHIVE_TIMEZONE=America/Chicago
VIDEO_ARCHIVE_ROOT=/data2/HighwayVLM
VIDEO_ARCHIVE_DURATION_SECONDS=3600
VIDEO_ARCHIVE_MAX_WORKERS=8
VIDEO_ARCHIVE_CAMERA_IDS=C842,C839,C30715,C837,C8361,C836,C8353,C8381
